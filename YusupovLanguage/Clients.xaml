<Page x:Class="YusupovLanguage.Clients"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:YusupovLanguage"
      mc:Ignorable="d"
      IsVisibleChanged="Page_IsVisibleChanged"
      d:DesignHeight="650"
      d:DesignWidth="1100"
      Background="White"
      FontFamily="Comic Sans MS">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <WrapPanel>
                <TextBlock Text="Поиск:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontSize="18"/>
                <TextBox x:Name="SearchTextBox"
                         Width="260"
                         Height="28"
                         Margin="0,0,15,0"
                         TextChanged="SearchTextBox_TextChanged"/>

                <TextBlock Text="Пол:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontSize="18"/>
                <ComboBox x:Name="GenderFilterComboBox"
                          Width="120"
                          Height="28"
                          Margin="0,0,15,0"
                          SelectionChanged="GenderFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Все" Tag="All" IsSelected="True"/>
                    <ComboBoxItem Content="женский" Tag="женский"/>
                    <ComboBoxItem Content="мужской" Tag="мужской"/>
                </ComboBox>

                <TextBlock Text="Сортировка:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontSize="18"/>
                <ComboBox x:Name="SortComboBox"
                          Width="260"
                          Height="28"
                          Margin="0,0,15,0"
                          SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="нет" Tag="" IsSelected="True"/>
                    <ComboBoxItem Content="по фамилии от А до Я" Tag="LastNameAsc"/>
                    <ComboBoxItem Content="по дате последнего посещения" Tag="LastVisitDesc"/>
                    <ComboBoxItem Content="по количеству посещений" Tag="VisitCountDesc"/>
                </ComboBox>

                <TextBlock Text="Выводить:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           FontSize="18"/>
                <ComboBox x:Name="PageSizeComboBox"
                          Width="90"
                          Height="28"
                          SelectionChanged="PageSizeComboBox_SelectionChanged">
                    <ComboBoxItem Content="10" Tag="10" IsSelected="True"/>
                    <ComboBoxItem Content="50" Tag="50"/>
                    <ComboBoxItem Content="200" Tag="200"/>
                    <ComboBoxItem Content="все" Tag="0"/>
                </ComboBox>
            </WrapPanel>
        </StackPanel>

        <ListView x:Name="ClientsListView"
          Grid.Row="1"
          Margin="0,10,0,10"
          BorderThickness="0"
          Background="Transparent"
          SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D9ECF7"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border x:Name="ClientBorder"
                    BorderBrush="#A7A7A7"
                    BorderThickness="1"
                    Background="White"
                    Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
                           Width="110"
                           Height="110"
                           Stretch="UniformToFill"
                           Source="{Binding PhotoFullPath}"/>

                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <TextBlock FontSize="20" TextWrapping="Wrap">
                            <Run Text="ID: "/>
                            <Run Text="{Binding ID}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding LastName}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding FirstName}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Patronymic}"/>
                                </TextBlock>

                                <WrapPanel Margin="0,10,0,0">
                                    <TextBlock FontSize="18" Text="Пол: "/>
                                    <TextBlock FontSize="18" Text="{Binding GenderName}"/>
                                    <TextBlock FontSize="18" Margin="15,0,0,0" Text="Дата рождения: "/>
                                    <TextBlock FontSize="18" Text="{Binding BirthdayString}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,10,0,0">
                                    <TextBlock FontSize="18" Text="Телефон: "/>
                                    <TextBlock FontSize="18" Text="{Binding Phone}"/>
                                    <TextBlock FontSize="18" Margin="20,0,0,0" Text="e-mail: "/>
                                    <TextBlock FontSize="18" Text="{Binding Email}"/>
                                </WrapPanel>

                                <WrapPanel Margin="0,10,0,0">
                                    <TextBlock FontSize="18" Text="Дата регистрации: "/>
                                    <TextBlock FontSize="18" Text="{Binding RegistrationDateString}"/>
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                                <Button Content="удалить"
                                Width="120"
                                Height="32"
                                Click="DeleteBtn_Click"
                                Tag="{Binding}"
                                Background="#04A0FF"
                                Foreground="White">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                            <Setter TargetName="ClientBorder" Property="Background" Value="#D9ECF7"/>
                            <Setter TargetName="ClientBorder" Property="BorderBrush" Value="#04A0FF"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="TBCount" FontSize="18" VerticalAlignment="Center"/>
            <TextBlock x:Name="TBAllRecords" FontSize="18" VerticalAlignment="Center" Margin="5,0,10,0"/>
            <Button x:Name="LeftDirButton"
                    Width="30"
                    Height="30"
                    Content="&lt;"
                    Margin="0,0,5,0"
                    Click="LeftDirButton_Click"/>
            <ListBox x:Name="PageListBox"
                     FontSize="18"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseUp="PageListBox_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button x:Name="RightDirButton"
                    Width="30"
                    Height="30"
                    Content=">"
                    Margin="5,0,0,0"
                    Click="RightDirButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
